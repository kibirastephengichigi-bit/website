DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stephenasatsa_v2?schema=public"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Single Domain Configuration
# All services (main website, Scholar Forge, admin panel, APIs) use one domain
# Set DOMAIN_NAME to your production domain (e.g., your-domain.com)
# For local development, use localhost
DOMAIN_NAME="localhost"

# NextAuth Configuration
# Must match your domain with protocol
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# API Configuration
# Leave empty to use Next.js proxy (recommended for single-domain)
# The main Next.js app will proxy /api/* requests to the backend
NEXT_PUBLIC_API_URL=""

# Scholar Forge Configuration
# Leave empty to use Next.js proxy (recommended for single-domain)
# The main Next.js app will proxy /scholars/* requests to Scholar Forge
# For production, this ensures everything is on one domain: your-domain.com/scholars
NEXT_PUBLIC_SCHOLARS_URL=""

# Admin Configuration
ADMIN_EMAIL="admin@localhost"
ADMIN_PASSWORD="ChangeMe123!"

# OAuth Configuration
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
