[Unit]
Description=Stephen Asatsa Website Backend API
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/home/codecrafter/Documents/combined/website/backend
Environment=PATH=/home/codecrafter/Documents/combined/website/backend/venv/bin
ExecStart=/home/codecrafter/Documents/combined/website/backend/venv/bin/python app.py
Restart=always
RestartSec=10
StandardOutput=append:/home/codecrafter/Documents/combined/website/backend/logs/app.log
StandardError=append:/home/codecrafter/Documents/combined/website/backend/logs/error.log

[Install]
WantedBy=multi-user.target
