# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stephenasatsa_v2?schema=public"

# NextAuth Configuration
NEXTAUTH_SECRET="CHANGE_THIS_TO_A_SECURE_64_CHARACTER_RANDOM_STRING"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Admin Credentials (FOR DEVELOPMENT ONLY - CHANGE IN PRODUCTION)
ADMIN_EMAIL="admin@stephenasatsa.com"
ADMIN_PASSWORD="CHANGE_THIS_TO_A_STRONG_PASSWORD"

# Google OAuth (Configure in Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id-here"
GOOGLE_CLIENT_SECRET="your-google-client-secret-here"

# Cloudinary (Configure for media uploads)
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Backend API (for future FastAPI integration)
NEXT_PUBLIC_API_URL="http://localhost:8000"
ADMIN_BACKEND_URL="http://localhost:8000/api"

# Security
JWT_SECRET="CHANGE_THIS_TO_A_SECURE_64_CHARACTER_RANDOM_STRING"
NEXTJS_REVALIDATE_SECRET="CHANGE_THIS_TO_A_SECURE_32_CHARACTER_RANDOM_STRING"
